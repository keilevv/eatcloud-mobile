{
  "expo": {
    "name": "EatCloud",
    "slug": "eatcloud-mobile",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eatcloud.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.eatcloud.mobile"
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}
